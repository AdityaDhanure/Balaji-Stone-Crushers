# ──── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ──── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get connection string from https://console.neon.tech
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require&channel_binding=require

# ──── JWT ─────────────────────────────────────────────────────────────────────
# Change this to a strong random secret in production!
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ──── Redis (optional — caching) ──────────────────────────────────────────────
# Redis is used to cache API responses (blast list, vehicles, attendance, etc.)
# and reduce repeated database queries. The server works without Redis —
# it falls back to always querying the DB if Redis is unavailable.
#
# Development (local Redis):
REDIS_URL=redis://localhost:6379
CACHE_TTL=300
#
# Production (Redis Cloud / Upstash / Railway etc.):
# REDIS_URL=rediss://<user>:<password>@<host>:<port>
